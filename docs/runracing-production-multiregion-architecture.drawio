        <mxCell id="badge-3" value="3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="520" y="700" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-4" value="4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="430" y="945" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-5" value="5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="300" y="690" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-6" value="6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="470" y="945" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-7" value="7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="700" y="940" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-8" value="8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="1015" y="1130" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-9" value="9" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="905" y="1240" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-10" value="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="700" y="400" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="badge-11" value="11" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="1115" y="690" width="28" height="28" as="geometry"/></mxCell>
        <mxCell id="legend-bg" value="" style="rounded=1;arcSize=60;absoluteArcSize=1;whiteSpace=wrap;html=1;fillColor=light-dark(#EDF3FF,#305363);strokeColor=#6c8ebf;strokeWidth=1;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="2510" y="210" width="660" height="1200" as="geometry"/></mxCell>
        <mxCell id="legend-title" value="Request &amp; data flow" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontFamily=Helvetica;fontColor=light-dark(#0A2540,#FFFFFF);" vertex="1" parent="1"><mxGeometry x="2534" y="228" width="600" height="30" as="geometry"/></mxCell>
        <mxCell id="leg-1-badge" value="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="268" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-1-desc" value="&lt;b&gt;Player entry&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Mobile clients resolve &lt;b&gt;Route 53&lt;/b&gt; latency records and reach the nearest healthy region's API.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="266" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-2-badge" value="2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="364" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-2-desc" value="&lt;b&gt;Authenticate&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;API Gateway&lt;/b&gt; validates the &lt;b&gt;Cognito&lt;/b&gt; JWT (age-gate / parental consent on first launch).&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="362" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-3-badge" value="3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="460" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-3-desc" value="&lt;b&gt;Backend API&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;API Gateway invokes in-VPC &lt;b&gt;Lambda&lt;/b&gt; handlers (profiles, tickets, leaderboards, entitlements).&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="458" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-4-badge" value="4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="556" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-4-desc" value="&lt;b&gt;Data + cache&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Lambda reads/writes &lt;b&gt;DynamoDB&lt;/b&gt; (PII, region-scoped, CMK+PITR) and &lt;b&gt;ElastiCache Redis&lt;/b&gt; leaderboards.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="554" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-5-badge" value="5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="652" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-5-desc" value="&lt;b&gt;Matchmaking&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Lambda submits a FlexMatch ticket; &lt;b&gt;GameLift&lt;/b&gt; places the session; client connects to the server over UDP.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="650" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-6-badge" value="6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="748" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-6-desc" value="&lt;b&gt;Telemetry&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Lambda and game servers emit events to &lt;b&gt;Kinesis Data Streams&lt;/b&gt;.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="746" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-7-badge" value="7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="844" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-7-desc" value="&lt;b&gt;Anti-cheat&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;Managed Service for Apache Flink&lt;/b&gt; applies real-time rules / anomaly detection and raises alerts.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="842" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-8-badge" value="8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="940" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-8-desc" value="&lt;b&gt;Data lake&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;Data Firehose&lt;/b&gt; batches events into the partitioned &lt;b&gt;S3&lt;/b&gt; Parquet data lake.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="938" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-9-badge" value="9" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="1036" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-9-desc" value="&lt;b&gt;Analytics&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;Glue&lt;/b&gt; catalogs the lake; &lt;b&gt;Athena&lt;/b&gt; queries it; &lt;b&gt;QuickSight&lt;/b&gt; serves KPI dashboards.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="1034" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-10-badge" value="10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="1132" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-10-desc" value="&lt;b&gt;Edge delivery&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;CloudFront&lt;/b&gt; (OAC) + &lt;b&gt;WAF&lt;/b&gt;/&lt;b&gt;Shield&lt;/b&gt; serve assets, updates and replays from S3.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="1130" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-11-badge" value="11" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2534" y="1228" width="40" height="38" as="geometry"/></mxCell>
        <mxCell id="leg-11-desc" value="&lt;b&gt;Active-active&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Non-PII &lt;b&gt;DynamoDB global tables&lt;/b&gt; (sessions, matchmaking) replicate multi-active across NA &#8596; EU.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;whiteSpace=wrap;labelBackgroundColor=none;" vertex="1" parent="1"><mxGeometry x="2588" y="1226" width="552" height="86" as="geometry"/></mxCell>
        <mxCell id="leg-note" value="&lt;i&gt;Cross-cutting (not numbered): &lt;b&gt;KMS&lt;/b&gt; CMKs encrypt DynamoDB, S3, Kinesis, ElastiCache &amp; Secrets; &lt;b&gt;Secrets Manager&lt;/b&gt; holds Stripe creds. Each region spans a 3-AZ VPC with S3/DynamoDB gateway endpoints. PII is region-scoped (never replicated cross-region); only non-PII uses global tables.&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;fontFamily=Helvetica;whiteSpace=wrap;fontColor=light-dark(#28415B,#E8EEF5);" vertex="1" parent="1"><mxGeometry x="2534" y="1328" width="606" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
